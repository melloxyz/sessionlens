{
  "name": "@sessionlens/backend",
  "version": "0.9.5",
  "private": true,
  "type": "module",
  "bin": {
    "sessionlens": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --import tsx --test src/**/*.test.ts",
    "test:coverage": "c8 node --import tsx --test src/**/*.test.ts",
    "diagnose:adapters": "node --import tsx src/scripts/adapter-diagnostics.ts",
    "backfill:quality": "node --import tsx src/scripts/backfill-adapter-quality.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@sessionlens/shared": "workspace:*",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "c8": "^10.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "c8": {
    "reporter": [
      "text",
      "lcov"
    ],
    "include": [
      "src/adapters/claude.ts",
      "src/adapters/codex.ts",
      "src/adapters/commandcode.ts",
      "src/adapters/opencode.ts",
      "src/ingestion/engine.ts",
      "src/ingestion/session-quality.ts",
      "src/costing.ts"
    ],
    "extension": [
      ".ts"
    ],
    "all": true,
    "lines": 70
  }
}
